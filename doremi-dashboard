function renderPembayaran(){
  const fi = document.getElementById('filter-status-pay')?.value||'';
  const tb = document.getElementById('tb-pembayaran'); if(!tb) return;

  let list = dataPembayaran.filter(p=>!fi||p.status===fi);
  const lunas = dataPembayaran.filter(p=>p.status==='Lunas');
  const belum = dataPembayaran.filter(p=>p.status!=='Lunas');

  document.getElementById('pay-lunas-count').textContent = lunas.length;
  document.getElementById('pay-pending-count').textContent = belum.length;
  document.getElementById('pay-total').textContent = 'Rp '+fmtRp(lunas.reduce((a,b)=>a+b.nominal,0));
  document.getElementById('pay-tunggak').textContent = 'Rp '+fmtRp(belum.reduce((a,b)=>a+b.nominal,0));

  tb.innerHTML = list.map((p,i)=>{
    const s = dataSiswa.find(x=>x.id===p.siswaId)||{nama:'-',instrumen:'-',tipe:'-'};
    return `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td>${s.nama}</td>
      <td><span class="instrumen-badge">${s.instrumen}</span></td>
      <td style="font-size:12px">${s.tipe}</td>
      <td>Rp ${fmtRp(p.nominal)}</td>
      <td style="font-size:12px;color:var(--muted)">${p.tgl||'—'}</td>
      <td><span class="badge-status ${p.status==='Lunas'?'badge-lunas':'badge-pending'}">${p.status==='Lunas'?'✓ Lunas':'⏳ Belum'}</span></td>
      <td>
        <div class="action-btns">
          ${p.status!=='Lunas'?`<button class="btn-sm btn-pay" onclick="markLunas(${p.id})">✓ Lunas</button>`:''}
          <button class="btn-sm btn-wa" onclick="sendWA('${s.wa||''}','${s.nama}',${p.nominal})">📱</button>
        </div>
      </td>
    </tr>`;
  }).join('') || '<tr class="loading-row"><td colspan="8">Tidak ada data</td></tr>';
}

function markLunas(id){
  const p = dataPembayaran.find(x=>x.id===id); if(!p) return;
  p.status='Lunas'; p.tgl=new Date().toISOString().split('T')[0]; p.metode='Tunai';
  dataHistori.unshift({tgl:p.tgl,nama:dataSiswa.find(s=>s.id===p.siswaId)?.nama||'-',instrumen:dataSiswa.find(s=>s.id===p.siswaId)?.instrumen||'-',periode:p.periode,nominal:p.nominal,metode:p.metode,status:'Lunas'});
  renderPembayaran();
  toast('Pembayaran ditandai Lunas! ✅','success');
  pushToSheets('pembayaran', p);
}

function openModalBayar(){
  const sel = document.getElementById('f-bayar-siswa');
  sel.innerHTML = dataSiswa.map(s=>`<option value="${s.id}">${s.nama} (${s.instrumen})</option>`).join('');
  showModal('modal-bayar');
}

function savePembayaran(){
  const siswaId = parseInt(document.getElementById('f-bayar-siswa').value);
  const periode = document.getElementById('f-bayar-periode').value;
  const nominal = parseInt(document.getElementById('f-bayar-nominal').value);
  const tgl = document.getElementById('f-bayar-tgl').value;
  const metode = document.getElementById('f-bayar-metode').value;

  // Update or add
  let ex = dataPembayaran.find(p=>p.siswaId===siswaId&&p.periode===periode);
  if(ex){ ex.status='Lunas'; ex.tgl=tgl; ex.metode=metode; ex.nominal=nominal; }
  else { dataPembayaran.push({id:Date.now(),siswaId,periode,nominal,tgl,metode,status:'Lunas',catatan:''}); }

  const s = dataSiswa.find(x=>x.id===siswaId)||{};
  dataHistori.unshift({tgl,nama:s.nama||'-',instrumen:s.instrumen||'-',periode,nominal,metode,status:'Lunas'});

  closeModal('modal-bayar');
  renderPembayaran();
  renderDashboard();
  toast('Pembayaran berhasil dicatat! 💰','success');
}

