      <div class="rem-info">
        <div class="rem-name">${s.nama||'-'} <span style="font-size:11px;color:var(--muted)"> — ${s.instrumen||'-'}</span></div>
        <div class="rem-detail">Tagihan ${p.periode} • Rp ${fmtRp(p.nominal)} • WA: ${s.wa||'-'}</div>
      </div>
      <div class="rem-actions">
        <button class="btn-sm btn-wa" onclick="sendWA('${s.wa||''}','${s.nama||''}',${p.nominal})">📱 Kirim WA</button>
      </div>
    </div>`;
  }).join('') || '<div style="padding:1.5rem;text-align:center;color:var(--muted);font-size:13px">✅ Tidak ada siswa yang perlu diingatkan!</div>';
}

function sendWA(wa, nama, nominal){
  const tmpl = document.getElementById('wa-template')?.value ||
    'Halo {nama}, tagihan SPP {bulan} sebesar {nominal} belum kami terima. Terima kasih — Doremi Music School';
  const now = new Date();
  const bulan = now.toLocaleDateString('id-ID',{month:'long',year:'numeric'});
  const msg = tmpl
    .replace(/{nama}/g, nama)
    .replace(/{bulan}/g, bulan)
    .replace(/{nominal}/g, 'Rp '+fmtRp(nominal))
    .replace(/{sekolah}/g, SETTINGS.sekolah);
  const url = `https://wa.me/${wa}?text=${encodeURIComponent(msg)}`;
  window.open(url,'_blank');
  toast('Membuka WhatsApp untuk '+nama+'...','info');
}

function sendAllReminder(){
  const belum = dataPembayaran.filter(p=>p.status!=='Lunas');
  if(!belum.length){ toast('Semua siswa sudah bayar! ✅','success'); return; }
  belum.forEach((p,i)=>{
    setTimeout(()=>{
      const s = dataSiswa.find(x=>x.id===p.siswaId)||{};
      sendWA(s.wa||'',s.nama||'-',p.nominal);
    },i*800);
  });
  toast(`Mengirim reminder ke ${belum.length} siswa...`,'info');
}

