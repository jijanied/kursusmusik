function downloadGASScript(){
  const script = `// Google Apps Script untuk Doremi Music School
// Paste ke: Google Sheets > Extensions > Apps Script

const SHEET_NAME_SISWA = 'Siswa';
const SHEET_NAME_PAYMENT = 'Pembayaran';
const SHEET_NAME_PROGRESS = 'Progress';

function doGet(e) {
  const action = e.parameter.action;
  const sheet = SpreadsheetApp.getActiveSpreadsheet();
  
  if (action === 'getSiswa') {
    const data = sheet.getSheetByName(SHEET_NAME_SISWA).getDataRange().getValues();
    return ContentService.createTextOutput(JSON.stringify(data)).setMimeType(ContentService.MimeType.JSON);
  }
  if (action === 'getPembayaran') {
    const data = sheet.getSheetByName(SHEET_NAME_PAYMENT).getDataRange().getValues();
    return ContentService.createTextOutput(JSON.stringify(data)).setMimeType(ContentService.MimeType.JSON);
  }
  return ContentService.createTextOutput(JSON.stringify({status:'ok'})).setMimeType(ContentService.MimeType.JSON);
}

function doPost(e) {
  const body = JSON.parse(e.postData.contents);
  const action = body.action;
  const sheet = SpreadsheetApp.getActiveSpreadsheet();
  
  if (action === 'addSiswa') {
    const s = sheet.getSheetByName(SHEET_NAME_SISWA);
    s.appendRow([body.id,body.nama,body.instrumen,body.jadwal,body.tipe,body.wali,body.wa,body.mulai,body.catatan]);
    return ContentService.createTextOutput(JSON.stringify({status:'ok'})).setMimeType(ContentService.MimeType.JSON);
  }
  if (action === 'addPembayaran') {
    const s = sheet.getSheetByName(SHEET_NAME_PAYMENT);
    s.appendRow([body.id,body.siswaId,body.periode,body.nominal,body.tgl,body.metode,body.status]);
    return ContentService.createTextOutput(JSON.stringify({status:'ok'})).setMimeType(ContentService.MimeType.JSON);
  }
  return ContentService.createTextOutput(JSON.stringify({status:'error'})).setMimeType(ContentService.MimeType.JSON);
}`;
  download('doremi-script.gs', script, 'text/plain');
  toast('Script Google Apps Script didownload! 📜','success');
}

