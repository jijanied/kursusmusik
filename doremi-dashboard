function renderSiswa(){
  const q = (document.getElementById('search-siswa')?.value||'').toLowerCase();
  const fi = document.getElementById('filter-instr')?.value||'';
  const tb = document.getElementById('tb-siswa');
  if(!tb) return;

  let list = dataSiswa.filter(s=>{
    const matchQ = !q || s.nama.toLowerCase().includes(q) || s.instrumen.toLowerCase().includes(q);
    const matchI = !fi || s.instrumen===fi;
    return matchQ && matchI;
  });

  tb.innerHTML = list.length ? list.map((s,i)=>{
    const bayar = dataPembayaran.find(p=>p.siswaId===s.id&&p.periode.includes('Mei'));
    const status = bayar?.status||'Belum';
    return `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td><strong>${s.nama}</strong></td>
      <td><span class="instrumen-badge">${s.instrumen}</span></td>
      <td style="font-size:12px;color:var(--muted)">${s.jadwal}</td>
      <td style="font-size:12px">${s.tipe}</td>
      <td style="font-size:12px;color:var(--muted)">${s.wali}</td>
      <td style="font-size:12px">${s.wa}</td>
      <td><span class="badge-status ${status==='Lunas'?'badge-lunas':'badge-pending'}">${status==='Lunas'?'✓':'⏳'} ${status}</span></td>
      <td>
        <div class="action-btns">
          <button class="btn-sm btn-edit" onclick="editSiswa(${s.id})">✏️ Edit</button>
          <button class="btn-sm btn-wa" onclick="sendWA('${s.wa}','${s.nama}',${s.tipe==='Bulanan'?350000:900000})">📱</button>
          <button class="btn-sm btn-del" onclick="deleteSiswa(${s.id})">🗑️</button>
        </div>
      </td>
    </tr>`;
  }).join('') : '<tr class="loading-row"><td colspan="9">Tidak ada data siswa</td></tr>';
}

function openModalSiswa(){ editSiswaId=null; document.getElementById('modal-siswa-title').textContent='Tambah Siswa Baru'; clearForm(['f-nama','f-lahir','f-instrumen','f-jadwal','f-wali','f-wa','f-tipe','f-mulai','f-catatan']); showModal('modal-siswa'); }

function editSiswa(id){
  const s = dataSiswa.find(x=>x.id===id); if(!s) return;
  editSiswaId = id;
  document.getElementById('modal-siswa-title').textContent = 'Edit Data Siswa';
  document.getElementById('f-nama').value = s.nama;
  document.getElementById('f-lahir').value = s.lahir;
  document.getElementById('f-instrumen').value = s.instrumen;
  document.getElementById('f-jadwal').value = s.jadwal;
  document.getElementById('f-wali').value = s.wali;
  document.getElementById('f-wa').value = s.wa;
  document.getElementById('f-tipe').value = s.tipe;
  document.getElementById('f-mulai').value = s.mulai;
  document.getElementById('f-catatan').value = s.catatan;
  showModal('modal-siswa');
}

function saveSiswa(){
  const nama = document.getElementById('f-nama').value.trim();
  const wa = document.getElementById('f-wa').value.trim();
  if(!nama||!wa){ toast('Nama dan nomor WA wajib diisi!','error'); return; }

  const data = {
    nama, lahir:document.getElementById('f-lahir').value,
    instrumen:document.getElementById('f-instrumen').value,
    jadwal:document.getElementById('f-jadwal').value,
    wali:document.getElementById('f-wali').value,
    wa, tipe:document.getElementById('f-tipe').value,
    mulai:document.getElementById('f-mulai').value,
    catatan:document.getElementById('f-catatan').value,
    aktif:true
  };

  if(editSiswaId){
    const idx = dataSiswa.findIndex(x=>x.id===editSiswaId);
    dataSiswa[idx] = {...dataSiswa[idx],...data};
    toast('Data siswa berhasil diupdate! ✅','success');
  } else {
    data.id = nextId++;
    dataSiswa.push(data);
    toast('Siswa baru berhasil ditambahkan! 🎵','success');
  }

  closeModal('modal-siswa');
  renderSiswa();
  pushToSheets('siswa', data);
}

function deleteSiswa(id){
  if(!confirm('Hapus data siswa ini?')) return;
  dataSiswa = dataSiswa.filter(s=>s.id!==id);
  renderSiswa();
  toast('Data siswa dihapus','info');
}

