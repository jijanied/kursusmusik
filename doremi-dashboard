function testConnection(){
  if(!SHEETS_URL){ toast('Isi URL Google Apps Script terlebih dahulu','error'); return; }
  toast('Menguji koneksi...','info');
  fetch(SHEETS_URL+'?action=ping')
    .then(r=>r.json())
    .then(()=>{ toast('Koneksi berhasil! Google Sheets terhubung ✅','success'); updateAPIStatus(true); })
    .catch(()=>{ toast('Gagal terhubung. Periksa URL dan permissions Apps Script','error'); updateAPIStatus(false); });
}

function loadFromSheets(){
  if(!SHEETS_URL){ toast('Belum ada URL Google Sheets yang dikonfigurasi','error'); return; }
  toast('Sync dari Google Sheets...','info');
  fetch(SHEETS_URL+'?action=getSiswa')
    .then(r=>r.json())
    .then(data=>{
      if(Array.isArray(data)&&data.length>1){
        const headers = data[0];
        dataSiswa = data.slice(1).map((row,i)=>{
          const obj = {};
          headers.forEach((h,j)=>obj[h]=row[j]);
          return {...obj, id:obj.id||i+1};
        });
        renderSiswa();
        toast('Data berhasil disinkronkan dari Sheets! ✅','success');
      }
    })
    .catch(()=>toast('Gagal mengambil data dari Sheets','error'));
}

async function pushToSheets(action, data){
  if(!SHEETS_URL) return;
  try {
    await fetch(SHEETS_URL, {
      method:'POST',
      body: JSON.stringify({action: 'add'+action.charAt(0).toUpperCase()+action.slice(1), ...data}),
      headers:{'Content-Type':'application/json'}
    });
  } catch(e){ console.log('Sheets push failed (demo mode)'); }
}

function updateAPIStatus(ok){
  document.getElementById('status-dot').style.background = ok?'#4CAF50':'#F44336';
  document.getElementById('status-text').textContent = ok?'Sheets Terhubung':'Offline / Demo';
}

