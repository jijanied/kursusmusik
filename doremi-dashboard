function initDashboard(){
  // Date
  const now = new Date();
  document.getElementById('topbar-date').textContent =
    now.toLocaleDateString('id-ID',{weekday:'long',day:'numeric',month:'long',year:'numeric'});

  // Today in form
  const today = now.toISOString().split('T')[0];
  if(document.getElementById('f-bayar-tgl')) document.getElementById('f-bayar-tgl').value = today;
  if(document.getElementById('f-mulai')) document.getElementById('f-mulai').value = today;

  renderDashboard();
  renderSiswa();
}

