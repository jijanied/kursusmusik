function renderDashboard(){
  const belumBayar = dataPembayaran.filter(p=>p.status==='Belum');
  const lunasCount = dataPembayaran.filter(p=>p.status==='Lunas').length;
  const totalLunas = dataPembayaran.filter(p=>p.status==='Lunas').reduce((a,b)=>a+b.nominal,0);
  const totalBelum = belumBayar.reduce((a,b)=>a+b.nominal,0);

  document.getElementById('stat-siswa').textContent = dataSiswa.filter(s=>s.aktif).length;
  document.getElementById('stat-pendapatan').textContent = 'Rp '+fmtRp(totalLunas);
  document.getElementById('stat-tunggakan').textContent = 'Rp '+fmtRp(totalBelum);
  document.getElementById('stat-lunas').textContent = lunasCount+'/'+dataSiswa.length;

  // Table belum bayar
  const tb = document.getElementById('tb-belum-bayar');
  tb.innerHTML = belumBayar.map(p=>{
    const s = dataSiswa.find(x=>x.id===p.siswaId)||{};
    return `<tr>
      <td>${s.nama||'-'}</td>
      <td><span class="instrumen-badge">${s.instrumen||'-'}</span></td>
      <td>${s.tipe||'-'}</td>
      <td>Rp ${fmtRp(p.nominal)}</td>
      <td>${s.wa||'-'}</td>
      <td><button class="btn-sm btn-wa" onclick="sendWA('${s.wa}','${s.nama}','${p.nominal}')">📱 Ingatkan</button></td>
    </tr>`;
  }).join('') || '<tr class="loading-row"><td colspan="6">✅ Semua siswa sudah bayar bulan ini!</td></tr>';

